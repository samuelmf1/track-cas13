/*
 * -------------------------------------------------
 *  Cas13-TraCK Pipeline Configuration
 * -------------------------------------------------
 */

manifest {
    name            = 'Cas13-TraCK'
    author          = 'Samuel Friedman'
    homePage        = 'https://github.com/samuelmf1/tracklib'
    description     = 'Pipeline for Cas13 guide RNA design and off-target analysis'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.10.0'
    version         = '1.1.0'
}

// Global default parameters
params {
    // Pipeline Options
    help            = false
    resume          = true
    gencode_version = "v49"
    n_chunks        = 100
    small_test      = false
    level           = "gene" 
    required_total  = 5

    // Paths
    projectDir      = "/gpfs/commons/home/sfriedman/projects/tracklib"
    data_dir        = "${params.projectDir}/datasets"
    
    // Input Files (Expression)
    expr_file       = "${params.data_dir}/expression/OmicsExpressionTranscriptTPMLogp1HumanAllGenesStranded_25Q3.parquet"
    model_file      = "${params.data_dir}/expression/Model_25Q3.csv"
    
    // Output / Scratch
    sort_tmp_dir     = '/gpfs/commons/home/sfriedman/tmp'
    sort_buffer_size = '60G'

    // ------------------------------------------------------------------------
    // TIGER Model Configuration
    // ------------------------------------------------------------------------
    tiger_hf            = "https://huggingface.co/spaces/Knowles-Lab/tiger"
    tiger_version       = "3d4c096"
    tiger_path          = "tiger"
    tiger_script        = "tiger/tiger_pipeline.py"
    tiger_src           = "${params.projectDir}/src/ontarget_tiger_pipeline.py"

    // ------------------------------------------------------------------------
    // Sassy Configuration
    // ------------------------------------------------------------------------
    skip_sassy              = true
    sassy_bin               = "/gpfs/commons/home/sfriedman/.cargo/bin/sassy"
    seqs_per_sassy_subchunk = 5000
    publish_subchunks       = false
    sassy_ref               = "${params.data_dir}/index/gencode.${params.gencode_version}.filtered.fa"
    sassy_cache             = "${params.data_dir}/index/sassy_cache.txt"

    // ------------------------------------------------------------------------
    // Off-Target Index
    // ------------------------------------------------------------------------
    fm_index = "${params.data_dir}/index/gencode.${params.gencode_version}.transcripts"

    // ------------------------------------------------------------------------
    // Scripts (src/)
    // ------------------------------------------------------------------------
    preproc_cds_boundaries_script          = "${params.projectDir}/src/preproc_cds_boundaries.py"
    preproc_reduce_fasta_script            = "${params.projectDir}/src/preproc_reduce_fasta.py"
    preproc_reduce_fasta_validation_script = "${params.projectDir}/src/preproc_validation_gencode.py"
    preproc_expr_script                    = "${params.projectDir}/src/preproc_expression.py"
    preproc_exon_script                    = "${params.projectDir}/src/preproc_exons.py"

    ontarget_chunk_fasta_script           = "${params.projectDir}/src/ontarget_chunk_fasta.py"
    ontarget_prefilter_poly_script        = "${params.projectDir}/src/ontarget_prefilter_poly.awk"
    
    offtarget_create_fasta_script         = "${params.projectDir}/src/offtarget_create_fasta.awk"
    offtarget_condense_bt_script          = "${params.projectDir}/src/offtarget_condense_bt.awk"
    offtarget_postfilter_bt_script        = "${params.projectDir}/src/offtarget_postfilter_bt.sh"
    offtarget_filter_cigar_script         = "${params.projectDir}/src/offtarget_filter_cigar.py"
    offtarget_sassy_filter_script         = "${params.projectDir}/src/offtarget_filter_sassy.awk"
    offtarget_monitor_sassy_script        = "${params.projectDir}/src/offtarget_monitor_sassy.sh"

    reduce_annot_script                   = "${params.projectDir}/src/reduce_annotate.py"
    reduce_tag_script                     = "${params.projectDir}/src/reduce_tagged_annotations.py"
    reduce_collapse_script                = "${params.projectDir}/src/reduce_collapse.py"
    reduce_sassy_script                   = "${params.projectDir}/src/reduce_sassy.py"
    reduce_constitutive_script            = "${params.projectDir}/src/reduce_constitutive.py"
    reduce_utr_script                     = "${params.projectDir}/src/reduce_utr_library.py"
}

executor {
  queueSize = 196
  submitRateLimit = '100/2min'
}

// ------------------------------------------------------------------------
// Profiles: standard (Slurm), local, test
// ------------------------------------------------------------------------
profiles {
    slurm {
        process.executor      = 'slurm'
        process.queue         = 'cpu'
    }
    
    local {
        process.executor      = 'local'
        process.cpus          = 2
        process.memory        = '8 GB'
    }
    
    test {
        params.small_test   = true
        process.executor      = 'slurm'
        process.queue         = 'cpu'
        params.n_chunks     = 50
    }
    
    debug {
        process.beforeScript = 'echo "DEBUG: Running on $HOSTNAME"'
        cleanup = false
    }
}

// Explicitly enable reporting and route to the runtime folder
trace {
    enabled = true
    file    = 'runtime/trace.txt'
    overwrite = true
}

timeline {
    enabled = true
    file    = 'runtime/timeline.html'
    overwrite = true
}

report {
    enabled = true
    file    = 'runtime/report.html'
    overwrite = true
}

dag {
    enabled = true
    file    = 'runtime/dag.dot'
    overwrite = true
}


// ------------------------------------------------------------------------
// Process Resources (Selectors)
// ------------------------------------------------------------------------
process {
    
    // Defaults
    cpus            = 1
    memory          = '25 GB'
    errorStrategy   = { task.exitStatus in [140, 143, 137, 104, 134, 139] ? 'retry' : 'terminate' }
    maxRetries      = 1
    cleanup         = { task.exitStatus == 0 }


    // Environment
    beforeScript = '''
        source ~/.bashrc
        module load cuDNN/8.5.0.96-CUDA-11.7.0
        module load seqkit
        conda activate track
    '''

    // Specific Resource Allocations
    
    withName: 'TIGER_FILTER|runTIGER' {
        memory = { 64.GB * task.attempt }
    }

    withName: 'BT_INDEX' {
        cpus = 27
    }

    withName: 'BT_ALIGN' {
        cpus = 6
    }

    withName: 'BT_FILTER' {
        cpus   = { 6 * task.attempt }
        memory = { 48.GB * task.attempt }
        time   = { 5.h  * task.attempt }
        scratch = true
    }

    withName: 'SASSY_SEARCH_CHUNK' {
        cpus   = { 16 * task.attempt }
        memory = { 32.GB * task.attempt }
        time   = '72 h'
        scratch = true
    }

    withName: 'expression' {
        memory = '32 GB'
    }

    withName: 'annotate' {
        memory = '32 GB'
    }

    withName: 'constitutive' {
        memory = { 8.GB * task.attempt }
    }

    // withName: 'isoform' {
    //     memory = '4 GB'
    // }

}